# ============================================================
# ArcTrader Environment Variables
# Copy this to .env and fill in your credentials.
# NEVER commit .env to git. It is gitignored.
# In cloud routines, set these as environment variables
# on the routine itself — do NOT create a .env file.
# ============================================================

# Alpaca (paper trading)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_ENDPOINT=https://paper-api.alpaca.markets/v2
ALPACA_DATA_ENDPOINT=https://data.alpaca.markets/v2

# xAI Grok (research)
XAI_API_KEY=your_xai_api_key_here

# Telegram (notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
